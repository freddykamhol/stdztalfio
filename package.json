{
  "name": "stundenalfio",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.20.0 <21"
  },
  "scripts": {
    "dev": "next dev",
    "prebuild": "npm run clean:next-public && npm run db:generate",
    "build": "next build",
    "clean:next-public": "node scripts/clear-public-next.mjs",
    "postbuild": "node scripts/copy-next-static.mjs",
    "prestart": "npm run prepare:sqlite && npm run validate:runtime-env && npm run db:migrate:deploy",
    "start": "node server.js",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:safe": "node scripts/migrate-existing-sqlite.mjs",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "postinstall": "npm run db:generate",
    "prepare:sqlite": "node scripts/prepare-sqlite.mjs",
    "validate:runtime-env": "node scripts/validate-runtime-env.mjs",
    "launch:production": "npm run build && npm run start"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "framer-motion": "^12.34.0",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "pdf-lib": "^1.17.1",
    "prisma": "^6.19.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.24",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "type": "module"
}
