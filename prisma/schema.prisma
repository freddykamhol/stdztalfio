generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum TimeEntryStatus {
  DRAFT
  RUNNING
  SUBMITTED
  APPROVED
  REJECTED
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  users     User[]
  projects  Project[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id          String      @id @default(cuid())
  workspaceId String
  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String?
  email       String      @unique
  timeEntries TimeEntry[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([workspaceId])
}

model Project {
  id          String      @id @default(cuid())
  workspaceId String
  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  slug        String
  description String?
  color       String      @default("#E20613")
  isArchived  Boolean     @default(false)
  timeEntries TimeEntry[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([workspaceId, slug])
  @@index([workspaceId, isArchived])
}

model TimeEntry {
  id        String          @id @default(cuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String
  project   Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  date      DateTime
  minutes   Int
  note      String?
  status    TimeEntryStatus @default(DRAFT)
  startAt   DateTime?
  endAt     DateTime?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([userId, projectId, date])
  @@index([projectId, date])
  @@index([userId, date])
  @@index([status, date])
}

model Stunde {
  id            String   @id @default(cuid())
  datum         DateTime @db.Date
  beginn        DateTime @db.Time(0)
  ende          DateTime @db.Time(0)
  pauseDauer    Int      @default(0)
  stundenGes    Decimal  @db.Decimal(5, 2)
  baustellen    String
  uebernachtung Boolean  @default(false)
  tankKosten    Decimal  @default(0) @db.Decimal(10, 2)
  bildNotizPfad String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([datum])
  @@index([baustellen])
  @@map("stunden")
}
